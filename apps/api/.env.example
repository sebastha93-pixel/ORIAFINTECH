NODE_ENV=development
PORT=3001

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Auth
RESET_PASSWORD_URL=nexofinanzas://reset-password
# Admin secret for protected maintenance endpoints (long random string)
ADMIN_SECRET=change-me-to-a-long-random-string

# CORS — explicit allowlist of frontend origins (comma-separated).
# In production this MUST be set; *.vercel.app previews are only auto-allowed
# outside production.
ALLOWED_ORIGINS=http://localhost:19006,http://localhost:3000

# Security hardening
# Secret used to sign Gmail OAuth `state` (defaults to the service-role key if unset).
OAUTH_STATE_SECRET=change-me-to-a-long-random-string
# Enables AES-256-GCM encryption of Gmail tokens at rest. Any string; a 32-byte
# key is derived from it. If unset, tokens are stored unencrypted (dev only).
OAUTH_TOKEN_KEY=change-me-to-a-long-random-string
# Set to 'true' to expose Swagger /docs (off by default in production).
ENABLE_SWAGGER=false

# Google OAuth (Gmail sync)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/v1/email-sync/auth/callback
