{
  "name": "oria",
  "version": "1.0.0",
  "private": true,
  "description": "ORIA - Personal Financial Intelligence Platform",
  "workspaces": {
    "packages": ["apps/*", "packages/*"],
    "nohoist": [
      "**/metro",
      "**/metro/**",
      "**/@expo/cli",
      "**/@expo/cli/**",
      "**/@expo/metro-config",
      "**/@expo/metro-config/**",
      "**/@expo/metro-runtime",
      "**/@expo/metro-runtime/**"
    ]
  },
  "scripts": {
    "api": "yarn workspace @nexo/api start:dev",
    "mobile": "yarn workspace @nexo/mobile start",
    "build:api": "yarn workspace @nexo/api build",
    "test:api": "yarn workspace @nexo/api test",
    "test:mobile": "yarn workspace @nexo/mobile test",
    "lint": "yarn workspaces run lint",
    "format": "yarn workspaces run format"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "yarn": ">=1.22.0"
  }
}
